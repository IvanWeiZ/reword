{
  "name": "reword",
  "version": "1.0.0",
  "description": "Chrome extension that flags problematic tone and suggests kinder rewrites before you hit Send",
  "scripts": {
    "dev": "vite build --watch",
    "build": "npx tsx build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/ tests/ build.ts",
    "lint:fix": "eslint src/ tests/ build.ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "check": "npm run format:check && npm run lint && npm test && npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "chrome-extension",
    "tone-checker",
    "ai",
    "communication",
    "gemini",
    "rewrite"
  ],
  "author": "IvanWeiZ",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.38",
    "@vitest/browser": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
